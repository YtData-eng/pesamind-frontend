const express = require('express');
const router = express.Router();
const multer = require('multer');
const pdfParse = require('pdf-parse');
const pool = require('../config/database');
const { authenticate } = require('../middleware/auth');
const { parseMpesaStatement, extractPeriod } = require('../utils/mpesaParser');
const { categorizeTransactions } = require('../services/aiService');

// Multer: memory storage, PDF only, max 10MB
const upload = multer({
  storage: multer.memoryStorage(),
  limits: { fileSize: 10 * 1024 * 1024 },
  fileFilter: (req, file, cb) => {
    if (file.mimetype === 'application/pdf') cb(null, true);
    else cb(new Error('Only PDF files are accepted'));
  }
});

// Upload & process statement
router.post('/upload', authenticate, upload.single('statement'), async (req, res) => {
  if (!req.file) return res.status(400).json({ error: 'No file uploaded' });

  const client = await pool.connect();
  try {
    // Extract text from PDF
    const pdfData = await pdfParse(req.file.buffer);
    const rawText = pdfData.text;

    if (!rawText || rawText.length < 100) {
      return res.status(422).json({ error: 'Could not extract text from PDF. Ensure it is a valid M-Pesa statement.' });
    }

    // Parse transactions
    const { transactions, totalIncome, totalExpenses } = parseMpesaStatement(rawText);
    const { start, end } = extractPeriod(rawText);

    if (transactions.length === 0) {
      return res.status(422).json({ error: 'No transactions found. Please upload a valid M-Pesa statement PDF.' });
    }

    // AI categorization (async, non-blocking for speed)
    let aiCategories = [];
    try {
      aiCategories = await categorizeTransactions(transactions);
    } catch (e) {
      console.warn('AI categorization skipped:', e.message);
    }

    await client.query('BEGIN');

    // Insert statement record
    const stmtResult = await client.query(
      `INSERT INTO statements (user_id, filename, period_start, period_end, total_income, total_expenses, raw_text, processed)
       VALUES ($1, $2, $3, $4, $5, $6, $7, TRUE)
       RETURNING id`,
      [req.user.id, req.file.originalname, start, end, totalIncome, totalExpenses, rawText.substring(0, 50000)]
    );
    const statementId = stmtResult.rows[0].id;

    // Insert transactions
    const txInserts = transactions.map((tx, i) => {
      const aiCat = aiCategories[i];
      const category = aiCat?.category || tx.category;
      const subcategory = aiCat?.subcategory || null;
      return client.query(
        `INSERT INTO transactions (statement_id, user_id, date, description, amount, type, category, subcategory, balance)
         VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9)`,
        [statementId, req.user.id, tx.date, tx.description, tx.amount, tx.type, category, subcategory, tx.balance]
      );
    });
    await Promise.all(txInserts);

    await client.query('COMMIT');

    res.status(201).json({
      message: 'Statement processed successfully',
      statement: {
        id: statementId,
        filename: req.file.originalname,
        period: { start, end },
        totalIncome,
        totalExpenses,
        transactionCount: transactions.length
      }
    });
  } catch (err) {
    await client.query('ROLLBACK');
    console.error('Upload error:', err);
    res.status(500).json({ error: 'Failed to process statement' });
  } finally {
    client.release();
  }
});

// Get all statements for user
router.get('/', authenticate, async (req, res) => {
  try {
    const result = await pool.query(
      `SELECT id, filename, period_start, period_end, total_income, total_expenses, processed, created_at
       FROM statements WHERE user_id = $1 ORDER BY created_at DESC`,
      [req.user.id]
    );
    res.json({ statements: result.rows });
  } catch (err) {
    res.status(500).json({ error: 'Failed to fetch statements' });
  }
});

// Get single statement with transactions
router.get('/:id', authenticate, async (req, res) => {
  try {
    const stmt = await pool.query(
      'SELECT * FROM statements WHERE id = $1 AND user_id = $2',
      [req.params.id, req.user.id]
    );
    if (stmt.rows.length === 0) return res.status(404).json({ error: 'Statement not found' });

    const txs = await pool.query(
      'SELECT * FROM transactions WHERE statement_id = $1 ORDER BY date DESC',
      [req.params.id]
    );

    const statement = { ...stmt.rows[0], raw_text: undefined };
    res.json({ statement, transactions: txs.rows });
  } catch (err) {
    res.status(500).json({ error: 'Failed to fetch statement' });
  }
});

// Delete statement
router.delete('/:id', authenticate, async (req, res) => {
  try {
    const result = await pool.query(
      'DELETE FROM statements WHERE id = $1 AND user_id = $2 RETURNING id',
      [req.params.id, req.user.id]
    );
    if (result.rows.length === 0) return res.status(404).json({ error: 'Statement not found' });
    res.json({ message: 'Statement deleted' });
  } catch (err) {
    res.status(500).json({ error: 'Failed to delete statement' });
  }
});

module.exports = router;